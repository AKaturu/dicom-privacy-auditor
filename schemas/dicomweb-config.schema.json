{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/krishna2006sai/dicom-privacy-auditor/schemas/dicomweb-config.schema.json",
  "title": "DICOM Privacy Auditor DICOMweb configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["base_url"],
  "properties": {
    "base_url": {"type": "string", "pattern": "^https?://"},
    "headers": {"type": "object", "additionalProperties": {"type": "string"}},
    "bearer_token_env": {"type": ["string", "null"]},
    "username_env": {"type": ["string", "null"]},
    "password_env": {"type": ["string", "null"]},
    "verify_tls": {"oneOf": [{"type": "boolean"}, {"type": "string"}]},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
    "max_retries": {"type": "integer", "minimum": 0},
    "allow_insecure_http": {"type": "boolean"},
    "allow_insecure_tls": {"type": "boolean"},
    "allow_literal_secret_headers": {"type": "boolean"},
    "include_error_body": {"type": "boolean"},
    "max_response_bytes": {"type": "integer", "minimum": 1},
    "max_request_bytes": {"type": "integer", "minimum": 1}
  }
}
