{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/krishna2006sai/dicom-privacy-auditor/schemas/study-run.schema.json",
  "title": "Atomic study processing run",
  "type": "object",
  "required": [
    "study_uid",
    "status",
    "source_instances",
    "processed_instances",
    "failed_instances",
    "output_directory",
    "started_at",
    "ended_at",
    "pipeline",
    "configuration_sha256",
    "application_version",
    "candidate_study_uid",
    "failures"
  ],
  "properties": {
    "study_uid": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?:0|[1-9][0-9]*)(?:\\.(?:0|[1-9][0-9]*))*$"
    },
    "status": {
      "enum": [
        "complete",
        "partial",
        "failed"
      ]
    },
    "source_instances": {
      "type": "integer",
      "minimum": 1
    },
    "processed_instances": {
      "type": "integer",
      "minimum": 0
    },
    "failed_instances": {
      "type": "integer",
      "minimum": 0
    },
    "output_directory": {
      "type": "string"
    },
    "started_at": {
      "type": "number",
      "minimum": 0
    },
    "ended_at": {
      "type": "number",
      "minimum": 0
    },
    "pipeline": {
      "type": "string"
    },
    "configuration_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "application_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "candidate_study_uid": {
      "type": [
        "string",
        "null"
      ]
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
