{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dicom-privacy-auditor/benchmark-manifest.schema.json",
  "title": "DICOM Privacy Auditor Benchmark Manifest",
  "type": "object",
  "required": [
    "benchmark_name",
    "version",
    "manifest_version",
    "seed",
    "standard_reference",
    "cases"
  ],
  "properties": {
    "benchmark_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "manifest_version": {
      "type": "string"
    },
    "seed": {
      "type": "integer"
    },
    "standard_reference": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "relative_path",
          "modality",
          "clean_control",
          "injections"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "relative_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
          },
          "modality": {
            "type": "string"
          },
          "clean_control": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object"
          },
          "injections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "injection_id",
                "stratum",
                "location_kind",
                "path",
                "value",
                "value_sha256"
              ],
              "properties": {
                "injection_id": {
                  "type": "string"
                },
                "stratum": {
                  "type": "string"
                },
                "location_kind": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                },
                "value_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "keyword": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "tag": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "bbox_xyxy": {
                  "oneOf": [
                    {
                      "type": "null"
                    },
                    {
                      "type": "array",
                      "minItems": 4,
                      "maxItems": 4,
                      "items": {
                        "type": "integer"
                      }
                    }
                  ]
                },
                "description": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "expected_action": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
