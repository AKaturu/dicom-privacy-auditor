{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/krishna2006sai/dicom-privacy-auditor/schemas/local-release-gate.schema.json",
  "title": "Local release gate report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release",
    "started_at",
    "finished_at",
    "environment",
    "scope",
    "status",
    "failed_checks",
    "skipped_checks",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "release": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python",
        "implementation",
        "platform",
        "architecture"
      ],
      "properties": {
        "python": {
          "type": "string"
        },
        "implementation": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "architecture": {
          "type": "string"
        }
      }
    },
    "scope": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "partial",
        "failed"
      ]
    },
    "failed_checks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "skipped_checks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "returncode",
          "duration_seconds",
          "command",
          "output_tail"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "returncode": {
            "type": [
              "integer",
              "null"
            ]
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          },
          "command": {
            "type": [
              "string",
              "null"
            ]
          },
          "output_tail": {
            "type": "string"
          }
        }
      }
    }
  }
}
