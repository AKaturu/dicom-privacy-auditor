{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/krishna2006sai/dicom-privacy-auditor/schemas/release-manifest.schema.json",
  "title": "Release bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release",
    "source_date_epoch",
    "generated_at",
    "local_release_gate",
    "artifacts",
    "external_validation_not_claimed"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "release": {
      "type": "string",
      "minLength": 1
    },
    "source_date_epoch": {
      "type": "integer",
      "minimum": 315532800
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "local_release_gate": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "sha256",
            "size_bytes",
            "media_type"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "size_bytes": {
              "type": "integer",
              "minimum": 1
            },
            "media_type": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "sha256",
          "size_bytes",
          "media_type"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "external_validation_not_claimed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
